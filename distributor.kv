#:kivy 2.3.1

<QRCode>:
    size: 500, 500
    canvas:
        Rectangle:
            pos: self.pos
            size: self.size

<Distribution>:
    canvas.before:
        Color:
            rgba: (1, 0.6, 1, 1)
        Rectangle:
            source:'back.jfif'
            size: root.width, root.height
            pos: self.pos